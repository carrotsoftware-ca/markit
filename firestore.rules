rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /projects/{projectId} {
      allow read, delete, write: if request.auth != null;

      // Unauthenticated portal read — token must match and portal must be active
      allow read: if resource.data.portalToken != null
                  && resource.data.portalToken == request.query.token
                  && resource.data.portalActive == true;

      // Files subcollection — replaces the old files[] array on the project document
      match /files/{fileId} {
        allow read, write: if request.auth != null;

        // Unauthenticated portal read — inherits token check from parent project
        allow read: if get(/databases/$(database)/documents/projects/$(projectId)).data.portalActive == true
                    && get(/databases/$(database)/documents/projects/$(projectId)).data.portalToken != null;

        // Events subcollection — append-only (no updates or hard deletes)
        // Soft deletes are handled by writing a { type: "delete" } event instead
        match /events/{eventId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow update: if false;
          allow delete: if false;

          // Unauthenticated portal read + write (add measurements via portal)
          allow read, create: if get(/databases/$(database)/documents/projects/$(projectId)).data.portalActive == true
                      && get(/databases/$(database)/documents/projects/$(projectId)).data.portalToken != null;
        }
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
