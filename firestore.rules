rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------------
    // Helper functions
    // ---------------------------------------------------------------------------

    // True when the caller owns the project document.
    function isProjectOwner(projectId) {
      return request.auth != null
          && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    // True when the portal is active and the caller presents the correct token.
    // Used for files/events subcollections — re-reads the parent project to
    // verify the token the client passed as a Firestore where() filter.
    function isValidPortalToken(projectId) {
      let proj = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return request.auth != null
          && proj.portalActive == true
          && proj.portalToken != null;
    }

    // ---------------------------------------------------------------------------
    // Users — own document only
    // ---------------------------------------------------------------------------

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------------------------
    // Projects
    // ---------------------------------------------------------------------------

    match /projects/{projectId} {
      // Create: caller must set themselves as owner
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      // Read / update / delete: owner only
      allow read, update, delete: if request.auth != null
                                  && resource.data.ownerId == request.auth.uid;

      // Unauthenticated portal read — the query itself filters by portalToken
      // and portalActive, so we just verify those fields on the matched document.
      // Anon-auth users are also permitted (request.auth may be set or null).
      allow read: if resource.data.portalActive == true
                  && resource.data.portalToken != null;

      // -------------------------------------------------------------------------
      // Activity feed — chat messages + system events
      // -------------------------------------------------------------------------
      match /activity/{eventId} {
        // Contractor: full read + append
        allow read, create: if isProjectOwner(projectId);
        // No one edits or hard-deletes activity events (append-only)
        allow update, delete: if false;

        // Portal client: read public events + send messages
        allow read: if isValidPortalToken(projectId)
                    && resource.data.visibleTo == "all";
        allow create: if isValidPortalToken(projectId)
                      && request.resource.data.visibleTo == "all"
                      && (
                        // Chat messages
                        (request.resource.data.type == "message"
                          && request.resource.data.keys().hasAll(["type", "actor", "authorId", "authorName", "visibleTo", "text", "createdAt"]))
                        ||
                        // File upload / delete system events
                        (request.resource.data.type in ["file_uploaded", "file_deleted"]
                          && request.resource.data.keys().hasAll(["type", "actor", "authorId", "authorName", "visibleTo", "payload", "createdAt"]))
                        ||
                        // Quote response events (accepted / rejected / revision requested)
                        (request.resource.data.type in ["quote_accepted", "quote_rejected", "quote_revision_requested"]
                          && request.resource.data.keys().hasAll(["type", "actor", "authorId", "authorName", "visibleTo", "payload", "createdAt"]))
                      );
      }

      // -------------------------------------------------------------------------
      // Portal sessions — written by the Cloud Function (admin SDK bypasses rules)
      // but readable by the project owner to show who has viewed the portal.
      // -------------------------------------------------------------------------
      match /portalSessions/{sessionId} {
        allow read: if isProjectOwner(projectId);
        allow write: if false; // Cloud Function only (admin SDK)
      }

      // -------------------------------------------------------------------------
      // Quote subcollection — projects/{projectId}/quote/current
      // -------------------------------------------------------------------------

      match /quote/{docId} {
        // Contractor: full read/write (save draft + send)
        allow read, write: if isProjectOwner(projectId);

        // Portal client: read the sent/accepted/rejected quote
        allow read: if isValidPortalToken(projectId)
                    && resource.data.status != "draft";

        // Portal client: respond to a quote (accept / reject / request revisions)
        // Only the status and respondedAt fields may change.
        allow update: if isValidPortalToken(projectId)
                      && resource.data.status == "sent"
                      && request.resource.data.status in ["accepted", "rejected", "revision_requested"]
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "respondedAt"]);
      }

      // -------------------------------------------------------------------------
      // Files subcollection
      // -------------------------------------------------------------------------

      match /files/{fileId} {
        // Owner: full read/write
        allow read, write: if isProjectOwner(projectId);

        // Portal: read existing files
        allow read: if isValidPortalToken(projectId);

        // Portal: create new file documents (client uploads).
        // Must have the required fields; status must start as "uploading".
        // update/delete remain locked — only the owner can modify existing docs.
        allow create: if isValidPortalToken(projectId)
                      && request.resource.data.keys().hasAll(["filename", "status", "size", "date", "storagePath"])
                      && request.resource.data.status == "uploading";

        // Portal: update status + url only — finalize an upload in progress.
        // Prevents clients from modifying filenames, storagePaths, etc.
        allow update: if isValidPortalToken(projectId)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "url", "progress"]);

        // Portal: delete their own file docs (e.g. client removes an uploaded file)
        allow delete: if isValidPortalToken(projectId);

        // -----------------------------------------------------------------------
        // Events subcollection — append-only, no updates or hard deletes.
        // Soft deletes use a { type: "delete", targetEventId: "..." } event.
        // -----------------------------------------------------------------------

        match /events/{eventId} {
          // Owner: full read + append
          allow read, create: if isProjectOwner(projectId);
          // No one can update or hard-delete an event
          allow update, delete: if false;

          // Portal: read valid events + append events.
          // Allowed types: measurement, calibration_line, calibration_confirmed,
          // and soft-delete. Hard writes of arbitrary fields are still blocked
          // by the per-type field checks below.
          allow read: if isValidPortalToken(projectId);
          allow create: if isValidPortalToken(projectId)
                        && (
                          // Measurement event
                          (request.resource.data.type == "measurement"
                            && request.resource.data.keys().hasAll(["type", "start", "end", "createdAt", "distanceText"]))
                          ||
                          // Calibration line event
                          (request.resource.data.type == "calibration_line"
                            && request.resource.data.keys().hasAll(["type", "start", "end", "createdAt"]))
                          ||
                          // Calibration confirmed event
                          (request.resource.data.type == "calibration_confirmed"
                            && request.resource.data.keys().hasAll(["type", "intrinsicScale", "refInput", "calibrationLineEventId", "createdAt"]))
                          ||
                          // Soft delete event
                          (request.resource.data.type == "delete"
                            && request.resource.data.keys().hasAll(["type", "targetEventId", "createdAt"]))
                        );
        }
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
