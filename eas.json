{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "credentialsSource": "remote"
      },
      "android": {
        "credentialsSource": "local"
      }
    },
    "preview": {
      "distribution": "store",
      "ios": {
        "credentialsSource": "remote"
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "credentialsSource": "local"
      },
      "android": {
        "credentialsSource": "local"
      }
    }
  },
  "submit": {
    "production": {},
    "preview": {}
  }
}
