rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Project files — owner only.
    // Files are stored at projects/{projectId}/files/{filename}.
    // We verify ownership by checking the Firestore project document so a user
    // can only read/write files that belong to their own projects.
    match /projects/{projectId}/{allPaths=**} {
      // Owner: full read/write
      allow read, write: if request.auth != null
                         && firestore.get(/databases/(default)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;

      // Portal client: read only (view existing files) + write only (upload new files).
      // Checked against the project document — no auth token required.
      allow read: if firestore.get(/databases/(default)/documents/projects/$(projectId)).data.portalActive == true;
      allow write: if firestore.get(/databases/(default)/documents/projects/$(projectId)).data.portalActive == true
                   && request.resource.size < 50 * 1024 * 1024; // 50 MB cap per file
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}